# =============================================================================
# SafeDetect — Root Environment Variables Template
# Copy this file to .env and fill in your values:  cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# KAFKA (shared by cv-service and ws-bridge)
# -----------------------------------------------------------------------------
# For Docker Compose deployment: use the service name "kafka" and port 9092
# For native development:         use "localhost" and port 29092
KAFKA_HOST=kafka
KAFKA_PORT=9092
KAFKA_TOPIC=detections

# -----------------------------------------------------------------------------
# COMPUTER VISION SERVICE (backend_Python)
# -----------------------------------------------------------------------------

# Path to the YOLOv8 weights file inside the container
MODEL_PATH=/app/backend/yolov8n.pt

# Detection confidence threshold (0.0 – 1.0)
MODEL_CONFIDENCE=0.5

# Camera sources — three modes per camera zone:
#   Mode A (USB webcam index):  set *_CAMERA_ID
#   Mode B (RTSP stream):       set *_CAMERA_SRC=rtsp://user:pass@192.168.1.10:554/stream
#   Mode C (video file):        set *_CAMERA_SRC=/app/videos/left.mp4
# *_CAMERA_SRC takes priority over *_CAMERA_ID when both are set.
LEFT_CAMERA_ID=0
RIGHT_CAMERA_ID=1
REAR_CAMERA_ID=2
# LEFT_CAMERA_SRC=
# RIGHT_CAMERA_SRC=
# REAR_CAMERA_SRC=

# Camera capture resolution and target FPS
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
FPS_TARGET=15

# YOLO inference size (640 recommended for GPU, 416 for CPU)
INFERENCE_SIZE=640

# Audio alert settings (pygame)
ALERT_BEEP_FREQUENCY=800
ALERT_DURATION=0.5

# HMAC key for per-detection integrity signing — change this in production!
DETECTION_SECRET_KEY=change_me_in_production

# Kafka security (leave as PLAINTEXT for local development)
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=
# KAFKA_SSL_CAFILE=
# KAFKA_SSL_CERTFILE=
# KAFKA_SSL_KEYFILE=

# -----------------------------------------------------------------------------
# WS-BRIDGE (Dashboard_Service/backend_Kafka)
# -----------------------------------------------------------------------------

# Kafka broker address seen by the Node.js bridge
# Docker Compose: kafka:9092    Native dev: localhost:29092
KAFKA_BROKER=kafka:9092

# HTTP health-check port for the bridge
PORT=8082
