# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_HOST=kafka          # Use 'kafka' inside Docker, 'localhost' for native run
KAFKA_PORT=9092
KAFKA_TOPIC=detections

# ── YOLO model ────────────────────────────────────────────────────────────────
MODEL_PATH=/app/backend/yolov8n.pt   # Docker path; omit or set to yolov8n.pt for native run

# ── Camera sources ────────────────────────────────────────────────────────────
# Option A – USB webcam index (requires usbipd-win passthrough on Windows Docker)
LEFT_CAMERA_ID=0
RIGHT_CAMERA_ID=1
REAR_CAMERA_ID=2

# Option B – RTSP stream (takes priority over *_CAMERA_ID when set)
# LEFT_CAMERA_SRC=rtsp://192.168.1.10:554/stream1
# RIGHT_CAMERA_SRC=rtsp://192.168.1.11:554/stream1
# REAR_CAMERA_SRC=rtsp://192.168.1.12:554/stream1

# Option C – Video file (useful for testing without cameras)
# LEFT_CAMERA_SRC=/app/backend/videos/left.mp4
# RIGHT_CAMERA_SRC=/app/backend/videos/right.mp4
# REAR_CAMERA_SRC=/app/backend/videos/rear.mp4

# ── Detection tuning ──────────────────────────────────────────────────────────
MODEL_CONFIDENCE=0.5
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
FPS_TARGET=15
